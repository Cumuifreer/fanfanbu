      "id": "dish-white-baizhuo-shengcai",
      "name": "白灼生菜",
      "category": "white",
      "ingredients": [
        "生菜",
        "蒜末",
        "蚝油",
        "生抽"
      ],
      "recipeSteps": [
        "生菜洗净后热水快速焯熟，控水摆盘。",
        "蒜末用少量油炒香，加入蚝油和生抽调匀。",
        "把热汁直接淋在生菜上即可。"
      ],
